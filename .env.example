# 复制为 .env.local 后按需填写（Vite 只会注入以 VITE_ 开头的变量）
#
# 可选：统计脚本（缺省不影响页面正常打开）
VITE_ANALYTICS_ENDPOINT=
VITE_ANALYTICS_WEBSITE_ID=
#
# 可选：OAuth 登录（不填会导致登录按钮/跳转不可用）
VITE_OAUTH_PORTAL_URL=
VITE_APP_ID=
#
# 可选：地图（不填会导致地图加载失败）
VITE_FRONTEND_FORGE_API_KEY=
VITE_FRONTEND_FORGE_API_URL=https://forge.butterfly-effect.dev

# Auth
# Generate a long random value for production, for example: openssl rand -base64 32
AUTH_SECRET=

# GitHub OAuth
# Callback URL in GitHub OAuth App:
# https://your-domain.com/api/auth/github/callback
# https://global-history-lens.onrender.com/api/auth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
PUBLIC_APP_URL=
